---
import { APP, PROBAR, SITE } from '../config';
---

<header class="absolute inset-x-0 top-0 z-10 px-4 py-6 sm:px-6 sm:py-8">
  <div class="mx-auto flex w-full max-w-6xl items-center justify-between">
    <a href="/" class="shrink-0">
      <img
        src="/images/logo-moneydiary.png"
        alt={SITE.title}
        width={80}
        height={70}
        class="h-[70px] w-auto sm:h-[120px]"
      />
    </a>
    <nav class="flex items-center gap-3 sm:gap-4" aria-label="Acceso">
      <a
        href={PROBAR.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-[44px] items-center justify-center rounded-xl bg-primary-container px-3 py-1.5 text-body-sm font-semibold text-on-primary-container shadow-sm transition-colors hover:bg-primary hover:text-on-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary sm:px-5 sm:py-2 sm:text-body-md"
      >
        {PROBAR.label}
      </a>
      <a
        href={APP.url}
        class="inline-flex min-h-[44px] items-center justify-center rounded-xl px-3 py-1.5 text-body-sm font-semibold text-on-surface transition-colors hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary sm:px-5 sm:py-2 sm:text-body-md"
      >
        {APP.label}
      </a>
    </nav>
  </div>
</header>
