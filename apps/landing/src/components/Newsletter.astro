---
import { NEWSLETTER } from '../config';
---

<section id="newsletter" class="bg-primary-container/20 px-6 py-16 sm:py-24">
  <div class="mx-auto max-w-lg text-center">
    <h2
      class="text-headline-lg font-semibold tracking-tight text-on-surface"
    >
      Mantente al día
    </h2>
    <p class="mt-3 text-body-sm text-on-surface-variant">
      Recibe tips financieros y novedades de MoneyDiary directamente en tu
      correo.
    </p>

    {
      NEWSLETTER.action ? (
        <form
          class="mt-8 flex flex-col gap-4 sm:flex-row"
          action={NEWSLETTER.action}
          method="POST"
        >
          <label for="newsletter-email" class="sr-only">
            Correo electrónico
          </label>
          <input
            id="newsletter-email"
            type="email"
            name="email"
            required
            placeholder={NEWSLETTER.placeholder}
            class="min-h-[44px] flex-1 rounded-xl border border-outline bg-surface px-4 text-body-sm text-on-surface placeholder:text-on-surface-variant focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          />
          <button
            type="submit"
            class="min-h-[44px] rounded-xl bg-primary px-8 text-body-sm font-semibold text-on-primary transition-colors hover:bg-primary/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          >
            {NEWSLETTER.buttonLabel}
          </button>
        </form>
      ) : (
        <div class="mt-8 rounded-xl border border-outline/30 bg-surface-dim/30 px-6 py-6">
          <p class="text-body-sm font-medium text-on-surface-variant">
            Próximamente
          </p>
          <p class="mt-1 text-label-caps text-on-surface-variant">
            Suscripción a newsletter aún no disponible.
          </p>
        </div>
      )
    }

    <p class="mt-4 text-label-caps text-on-surface-variant">
      {NEWSLETTER.privacyNotice}
    </p>
  </div>
</section>
