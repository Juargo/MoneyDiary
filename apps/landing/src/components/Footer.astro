  <div
    class="mx-auto flex max-w-5xl flex-col items-center gap-4 sm:flex-row sm:justify-between"
  >
    <nav class="flex gap-6 text-sm text-on-surface-variant" aria-label="Legal">
      <a
        href="mailto:beta@moneydiary.cl"
        class="transition-colors hover:text-on-surface focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        Contacto
      </a>
      <a
        href="#"
        class="transition-colors hover:text-on-surface focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        Política de privacidad
      </a>
    </nav>
    <p class="text-sm text-on-surface-variant">
      &copy; {year} MoneyDiary. Todos los derechos reservados.
    </p>
  </div>
</footer>
