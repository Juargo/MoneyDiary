---
import { SOCIAL_PROOF } from '../config';
---

<section
  id="social-proof"
  class="bg-surface-container py-10 sm:py-12"
  aria-label="Indicadores de confianza"
>
  <div
    class="mx-auto flex max-w-3xl flex-col gap-8 px-6 sm:flex-row sm:items-center sm:justify-center sm:gap-14"
  >
    <div class="flex flex-col items-center text-center">
      <span class="text-display-lg font-bold text-on-surface">{SOCIAL_PROOF.users}</span>
      <span class="mt-1 text-body-sm text-on-surface-variant">usuarios registrados</span>
    </div>

    <div class="flex flex-col items-center text-center" aria-label={`${SOCIAL_PROOF.rating} de 5 estrellas`}>
      <span class="text-display-lg font-bold text-on-surface">{SOCIAL_PROOF.rating}</span>
      <span class="mt-1 text-body-sm text-on-surface-variant">★ calificación promedio</span>
    </div>

    <div class="flex flex-col items-center text-center">
      <span class="text-display-lg font-bold text-on-surface">{SOCIAL_PROOF.reviews}</span>
      <span class="mt-1 text-body-sm text-on-surface-variant">reseñas verificadas</span>
    </div>
  </div>
</section>
