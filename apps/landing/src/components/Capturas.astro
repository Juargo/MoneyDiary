---
const screenshots = [
  {
    src: '/images/screenshots/dashboard.svg',
    alt: 'Vista general del dashboard de MoneyDiary con saldo, regla 50/30/20 y movimientos recientes',
  },
  {
    src: '/images/screenshots/categoria.svg',
    alt: 'Desglose de gastos por categoría en MoneyDiary mostrando Necesidades, Deseos y Ahorro',
  },
  {
    src: '/images/screenshots/resumen.svg',
    alt: 'Resumen mensual con semáforo financiero, distribución de gastos y tendencia mensual en MoneyDiary',
  },
];
---

<section id="capturas" class="bg-surface-dim/50 px-6 py-16 sm:py-24">
  <h2
    class="text-center text-headline-lg font-semibold tracking-tight text-on-surface sm:text-4xl"
  >
    Así se ve MoneyDiary
  </h2>

  <p class="mx-auto mt-4 text-center text-body-sm text-on-surface-variant">
    Una interfaz limpia y moderna que te ayuda a entender tus finanzas de
    un vistazo.
  </p>

  <div
    class="mx-auto mt-10 grid max-w-4xl gap-6 sm:grid-cols-3"
  >
    {screenshots.map((s) => (
      <div
        class="flex aspect-[9/16] items-center justify-center overflow-hidden rounded-xl bg-surface-container-highest"
      >
        <img
          src={s.src}
          alt={s.alt}
          class="h-full w-full object-cover"
          loading="lazy"
        />
      </div>
    ))}
  </div>
</section>
