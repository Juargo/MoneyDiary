---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import ComoFunciona from '../components/ComoFunciona.astro';
import Bancos from '../components/Bancos.astro';
import Capturas from '../components/Capturas.astro';
import FAQ from '../components/FAQ.astro';
import CtaBeta from '../components/CtaBeta.astro';
import Newsletter from '../components/Newsletter.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Header />
  <main>
    <Hero />
    <SocialProof />
    <ComoFunciona />
    <Bancos />
    <Capturas />
    <FAQ />

    <!-- Final CTA section -->
    <section class="px-6 py-16 text-center sm:py-24">
      <h2
        class="text-3xl font-semibold tracking-tight text-on-surface sm:text-4xl"
      >
        ¿Listo para tomar el control?
      </h2>
      <p class="mx-auto mt-4 max-w-md text-on-surface-variant">
        Solicita acceso a la beta y empieza a entender tu dinero en
        profundidad.
      </p>
      <div class="mt-8">
        <CtaBeta />
      </div>
    </section>

    <Newsletter />
  </main>

  <Footer />
</Layout>
