# MoneyDiary mobile — environment template (Expo public vars).
# Copy to `.env` and fill in. Read at build-time by Metro and inlined into
# the compiled bundle (EXPO_PUBLIC_* prefix required).
#
# Security note (D4, design.md): EXPO_PUBLIC_API_KEY is embedded in the
# compiled binary and extractable from a downloaded build. Casual scraping
# deterrent, NOT real authentication.

# Base URL of the MoneyDiary API (no trailing slash).
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# API key sent with requests (see security note above).
EXPO_PUBLIC_API_KEY=
