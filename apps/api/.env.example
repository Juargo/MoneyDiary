# === MoneyDiary API — variables de entorno (ejemplo) ===
# Copiar a `.env` y rellenar. NUNCA commitear el .env real.

# --- Base de datos (Supabase / Postgres, ADR-002) ---
# Pooler transaction-mode (IPv4) para la app:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Pooler session-mode para migraciones:
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Seguridad de acceso (ApiKeyGuard, fase mono-usuario) ---
# API key exigida en el header `x-api-key` de cada request.
# El guard es fail-closed: si falta o mide < 16 chars, rechaza TODO.
# Generar una nueva con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY="reemplazar-por-una-key-aleatoria-de-64-hex"

# --- Runtime ---
# PORT lo inyecta Render en producción; en local por defecto 3000.
# PORT=3000
