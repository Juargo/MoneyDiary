# === MoneyDiary API — variables de entorno (ejemplo) ===
# Copiar a `.env` y rellenar. NUNCA commitear el .env real.

# --- Base de datos (Supabase / Postgres, ADR-002) ---
# Pooler transaction-mode (IPv4) para la app:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Pooler session-mode para migraciones:
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# --- Seguridad de acceso (ApiKeyGuard, fase mono-usuario) ---
# API key exigida en el header `x-api-key` de cada request.
# El guard es fail-closed: si falta o mide < 16 chars, rechaza TODO.
# Generar una nueva con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY="reemplazar-por-una-key-aleatoria-de-64-hex"

# --- Cookie de sesión (auth-login-session) ---
# Fuerza el flag `Secure` en la cookie de sesión. En producción va en "true"
# (ver render.yaml); en local se deja sin setear para poder probar sobre HTTP.
# COOKIE_SECURE=true

# --- Rate limiter de login (AUTH-08) ---
# Valores por defecto; el parseo es fail-closed (vacío/no-numérico/≤0 → la API
# no arranca). Descomentar solo para sobreescribir los defaults del código.
# LOGIN_RATELIMIT_MAX_EMAIL=5
# LOGIN_RATELIMIT_MAX_IP=20
# LOGIN_RATELIMIT_WINDOW_MS=900000

# --- Runtime ---
# PORT lo inyecta Render en producción; en local por defecto 3000.
# PORT=3000
