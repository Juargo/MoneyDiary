datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum EstadoIngesta {
  PENDIENTE
  PROCESADA
  FALLIDA
}

model User {
  id       String    @id @default(cuid())
  nombre   String
  creadoEn DateTime  @default(now())
  accounts Account[]
}

model Account {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  banco         String
  tipoCuenta    String
  numeroCuenta  String
  creadoEn      DateTime      @default(now())
  ingestas      Ingesta[]
  transacciones Transaccion[]

  @@unique([userId, banco, tipoCuenta, numeroCuenta])
}

model Ingesta {
  id                 String        @id @default(cuid())
  accountId          String
  account            Account       @relation(fields: [accountId], references: [id])
  banco              String
  nombreArchivo      String
  estado             EstadoIngesta @default(PENDIENTE)
  totalTransacciones Int?
  motivoFallo        String?
  creadoEn           DateTime      @default(now())
  procesadoEn        DateTime?
  transacciones      Transaccion[]
}

model BucketPresupuesto {
  id            String               @id
  nombre        String               @unique
  patrones      PatronClasificacion[]
  transacciones Transaccion[]
}

model PatronClasificacion {
  id        String            @id @default(cuid())
  patron    String
  matchType String
  bucketId  String
  bucket    BucketPresupuesto @relation(fields: [bucketId], references: [id])
  prioridad Int
}

model Transaccion {
  id          String             @id @default(cuid())
  ingestaId   String
  ingesta     Ingesta            @relation(fields: [ingestaId], references: [id])
  accountId   String
  account     Account            @relation(fields: [accountId], references: [id])
  fecha       DateTime
  descripcion String
  cargo       BigInt
  abono       BigInt
  bucketId    String?
  bucket      BucketPresupuesto? @relation(fields: [bucketId], references: [id])
  creadoEn    DateTime           @default(now())
}
