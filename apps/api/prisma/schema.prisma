datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum EstadoIngesta {
  PENDIENTE
  PROCESADA
  FALLIDA
}

model User {
  id            String    @id @default(cuid())
  nombre        String
  email         String?   @unique
  passwordHash  String?
  esDemo        Boolean   @default(false)
  demoCreatedAt DateTime?
  creadoEn      DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  expiresAt DateTime
  creadoEn  DateTime @default(now())

  @@index([userId])
}

model Account {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  banco         String
  tipoCuenta    String
  numeroCuenta  String
  creadoEn      DateTime      @default(now())
  ingestas      Ingesta[]
  transacciones Transaccion[]

  @@unique([userId, banco, tipoCuenta, numeroCuenta])
}

model Ingesta {
  id                 String        @id @default(cuid())
  accountId          String
  account            Account       @relation(fields: [accountId], references: [id])
  banco              String
  nombreArchivo      String
  estado             EstadoIngesta @default(PENDIENTE)
  totalTransacciones Int?
  motivoFallo        String?
  creadoEn           DateTime      @default(now())
  procesadoEn        DateTime?
  transacciones      Transaccion[]
}

model BucketPresupuesto {
  id            String                @id
  nombre        String                @unique
  patrones      PatronClasificacion[]
  transacciones Transaccion[]
  categorias    Categoria[]
}

// Categoria (US-013) — nivel más fino que Bucket; cada categoría pertenece a
// exactamente un bucket (invariante CAT-01, dueño real en domain/value-objects
// /categoria.ts vía CATEGORIA_BUCKET). Catálogo fijo, seed-only (sin
// categorías creadas por el usuario en MVP).
model Categoria {
  id            String                @id
  nombre        String                @unique
  bucketId      String
  bucket        BucketPresupuesto     @relation(fields: [bucketId], references: [id])
  patrones      PatronClasificacion[]
  transacciones Transaccion[]

  @@index([bucketId])
}

model PatronClasificacion {
  id          String            @id @default(cuid())
  patron      String
  matchType   String
  bucketId    String
  bucket      BucketPresupuesto @relation(fields: [bucketId], references: [id])
  // Slice S1 (dual-write window): nullable por ahora — bucketId se mantiene
  // como fuente de verdad hasta S2, que hace categoriaId NOT NULL y DROPea
  // bucketId (ver design.md §1.3). No behavior change en S1.
  categoriaId String?
  categoria   Categoria?        @relation(fields: [categoriaId], references: [id])
  prioridad   Int
}

model Transaccion {
  id          String             @id @default(cuid())
  ingestaId   String
  ingesta     Ingesta            @relation(fields: [ingestaId], references: [id])
  accountId   String
  account     Account            @relation(fields: [accountId], references: [id])
  fecha       DateTime
  descripcion String
  cargo       BigInt
  abono       BigInt
  bucketId    String?
  bucket      BucketPresupuesto? @relation(fields: [bucketId], references: [id])
  // Nullable para siempre (Ingreso/SinCategoria/no-match no tienen
  // categoría). onDelete SetNull: borrar una categoría NUNCA debe
  // cascade-borrar transacciones (dato de dinero). bucketId sigue siendo la
  // fuente de verdad del 50/30/20 (ver design.md §1.1).
  categoriaId String?
  categoria   Categoria?         @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  creadoEn    DateTime           @default(now())
}
